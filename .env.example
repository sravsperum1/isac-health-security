# ============================================
# Azure OpenAI Configuration Template
# ============================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace with your actual Azure credentials
# 3. NEVER commit .env to GitHub!
#
# Get your credentials from:
# Azure Portal → Your OpenAI Resource → Keys and Endpoint
# ============================================

AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name
AZURE_OPENAI_API_VERSION=2099-99-99-preview

# ============================================
# EXAMPLE VALUES (COMPLETELY FAKE - DO NOT USE)
# ============================================
# AZURE_OPENAI_API_KEY=fake_key_12345_abcde_67890
# AZURE_OPENAI_ENDPOINT=https://fake-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=fake-deployment-name
# AZURE_OPENAI_API_VERSION=2099-99-99-preview
# ============================================

# Note: The API version above does NOT exist.
# Replace with actual version from Azure Portal.
# Common real versions: 2024-08-01-preview, 2024-02-01, 2023-12-01-preview
